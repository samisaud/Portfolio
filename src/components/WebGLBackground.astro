---
<canvas id="dataCanvas"></canvas>

<style>
    #dataCanvas {
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        z-index: 1;
        opacity: 0.6;
        pointer-events: none;
    }
</style>

<script>
    const canvas = document.getElementById('dataCanvas') as HTMLCanvasElement;
    const scene = new (window as any).THREE.Scene();
    const camera = new (window as any).THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.z = 18;

    const renderer = new (window as any).THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const THREE = (window as any).THREE;

    const geometry = new THREE.SphereGeometry(7, 100, 100);
    const material = new THREE.PointsMaterial({
        size: 0.04, color: 0x0044ff, transparent: true, opacity: 0.45,
        blending: THREE.AdditiveBlending
    });

    const sphere = new THREE.Points(geometry, material);
    sphere.position.x = window.innerWidth < 900 ? 0 : 5;
    scene.add(sphere);

    const positions = geometry.attributes.position;
    const originalPositions: any[] = [];
    const vertex = new THREE.Vector3();

    for (let i = 0; i < positions.count; i++) {
        vertex.fromBufferAttribute(positions, i);
        originalPositions.push(vertex.clone());
    }

    let inputX = 0, inputY = 0;
    const windowHalfX = window.innerWidth / 2;
    const windowHalfY = window.innerHeight / 2;

    document.addEventListener('mousemove', (e) => {
        inputX = e.clientX - windowHalfX;
        inputY = e.clientY - windowHalfY;
    });

    document.addEventListener('touchmove', (e) => {
        inputX = e.touches[0].clientX - windowHalfX;
        inputY = e.touches[0].clientY - windowHalfY;
    }, { passive: true });

    let scrollY = 0;
    document.getElementById('view-container')?.addEventListener('scroll', (e) => {
        scrollY = (e.target as HTMLElement).scrollTop;
    });

    const clock = new THREE.Clock();

    function animate() {
        requestAnimationFrame(animate);
        const time = clock.getElapsedTime();

        sphere.rotation.y += 0.05 * ((inputX * 0.001) - sphere.rotation.y);
        sphere.rotation.x += 0.05 * ((inputY * 0.001) - sphere.rotation.x);
        sphere.rotation.z += 0.0005;

        const scrollVolatility = 1 + (scrollY * 0.001);

        for (let i = 0; i < positions.count; i++) {
            const u = originalPositions[i];
            const noise = Math.sin(u.x * 0.8 + time) * Math.cos(u.y * 0.8 + time) * Math.sin(u.z * 0.8 + time);
            const distortion = 1 + (noise * 0.3 * scrollVolatility);
            vertex.copy(u).multiplyScalar(distortion);
            positions.setXYZ(i, vertex.x, vertex.y, vertex.z);
        }

        positions.needsUpdate = true;
        renderer.render(scene, camera);
    }

    animate();

    window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
        sphere.position.x = window.innerWidth < 900 ? 0 : 5;
    });
</script>