                <!-- COMING SOON -->
                <div class="metric-block" style="background: rgba(255,255,255,0.01); border-style: dashed; opacity: 0.6;">
                    <span class="live-badge" style="background: rgba(212,175,55,0.1); border-color: rgba(212,175,55,0.3); color: var(--accent-gold);">⧗ IN PROGRESS</span>
                    <div style="margin-top: 20px;">
                        <h3>Arabic Document Intelligence</h3>
                        <p class="desc" style="margin-top: 10px;">Fine-tuned Arabic NLP model for contract analysis, clause extraction and risk flagging. Hybrid RAG with custom embeddings trained on Saudi legal corpus. Targeting Riyadh enterprise market.</p>
                        <div class="tag-container">
                            <span class="tag">Arabic NLP</span>
                            <span class="tag">RAG</span>
                            <span class="tag">Fine-tuning</span>
                            <span class="tag">Pinecone</span>
