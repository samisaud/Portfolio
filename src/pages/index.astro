                    <span class="label">MLOps · Fraud Detection · FastAPI · CI/CD</span>
                    <div class="spec-grid">
                        <div>
                            <span class="metric-value" style="font-size: clamp(1.8rem, 3.5vw, 3rem); line-height: 1.3;">End-to-End<br>Fraud Detection<br>Pipeline.</span>
                            <div class="tag-container" style="margin-top: 20px;">
                                <span class="tag">XGBoost</span>
                                <span class="tag">LightGBM</span>
                                <span class="tag">MLflow</span>
                                <span class="tag">DVC</span>
                                <span class="tag">FastAPI</span>
                                <span class="tag">SHAP</span>
                                <span class="tag">Evidently AI</span>
                                <span class="tag">GitHub Actions</span>
                                <span class="tag">Docker</span>
                                <span class="tag">SMOTE</span>
                            </div>
                        </div>
